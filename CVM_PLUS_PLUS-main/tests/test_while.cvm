// test_while.cvm
// Tests: while loop, counter, accumulator

// Count from 1 to 5
let i = 1;
while (i <= 5) {
    print i;
    i = i + 1;
}
// Expected: 1 2 3 4 5

// Sum 1..10 = 55
let sum = 0;
let n = 1;
while (n <= 10) {
    sum = sum + n;
    n = n + 1;
}
print sum;
// Expected: 55

// Factorial 5! = 120
let result = 1;
let k = 5;
while (k > 0) {
    result = result * k;
    k = k - 1;
}
print result;
// Expected: 120
